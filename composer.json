{
    "name": "lattice/observability",
    "description": "Structured logging, metrics, tracing, and health checks for LatticePHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "observability",
        "logging",
        "metrics",
        "tracing",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/observability"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Observability\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Observability\\Tests\\": "tests/"
        }
    }
}
