{
    "name": "lattice/observability",
    "description": "Structured logging, metrics, tracing, and health checks for LatticePHP",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "lattice/contracts": "dev-main",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Observability\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Observability\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../contracts"
        }
    ]
}
